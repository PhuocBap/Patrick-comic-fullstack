generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model NguoiDung {
  id           String      @id @default(cuid())
  tenDangNhap  String      @unique
  matKhau      String
  email        String?     @unique
  vaiTro       String      @default("USER")
  ngayTao      DateTime    @default(now())
  
  binhLuans    BinhLuan[]
  theoDois     TheoDoi[]
  lichSuDocs   LichSuDoc[]
}

model Truyen {
  id           Int       @id @default(autoincrement())
  tenTruyen    String
  // Cột này lưu tên truyện đã loại bỏ dấu để tìm kiếm cực nhạy
  tenKhongDau  String?   
  slug         String    @unique
  tacGia       String?
  moTa         String?
  // Đổi tên thành thumbnail để đồng nhất với code SearchBar bạn đang dùng
  thumbnail    String?   
  trangThai    String    @default("ĐANG_RA")
  luotXem      Int       @default(0)
  ngayTao      DateTime  @default(now())
  ngayCapNhat  DateTime  @updatedAt

  chuongs      Chuong[]
  binhLuans    BinhLuan[]
  theoDois     TheoDoi[]
  theLoais     TheLoai[]
  lichSuDocs   LichSuDoc[] 
  @@index([tenKhongDau]) 
  @@index([tenTruyen])
}

model TheLoai {
  id      String   @id @default(cuid())
  ten     String   @unique
  truyens Truyen[]
}

model Chuong {
  id           Int           @id @default(autoincrement())
  tenChuong    String
  soChuong     Float         
  noiDung      String        
  ngayCapNhat  DateTime      @default(now())
  
  truyenId     Int
  truyen       Truyen        @relation(fields: [truyenId], references: [id])
  trangTruyens TrangTruyen[]
  lichSuDocs   LichSuDoc[]
  binhLuans    BinhLuan[]

  @@unique([truyenId, soChuong]) // Quan trọng: Đảm bảo 1 truyện chỉ có 1 chương số X
}

model TrangTruyen {
  id       String @id @default(cuid())
  urlAnh   String
  soThuTu  Int
  
  chuongId Int
  chuong   Chuong @relation(fields: [chuongId], references: [id])
}

model BinhLuan {
  id           String    @id @default(cuid())
  noiDung      String
  ngayBinhLuan DateTime  @default(now())
  
  nguoiDungId  String
  nguoiDung    NguoiDung @relation(fields: [nguoiDungId], references: [id])
  
  truyenId     Int
  truyen       Truyen    @relation(fields: [truyenId], references: [id])
  
  chuongId     Int?      
  chuong       Chuong?   @relation(fields: [chuongId], references: [id])
}

model TheoDoi {
  id           String    @id @default(cuid())
  ngayTheoDoi  DateTime  @default(now())
  
  nguoiDungId  String
  nguoiDung    NguoiDung @relation(fields: [nguoiDungId], references: [id])
  
  truyenId     Int
  truyen       Truyen    @relation(fields: [truyenId], references: [id])

  @@unique([nguoiDungId, truyenId])
}

model LichSuDoc {
  id           String   @id @default(cuid())
  thoiGianDoc  DateTime @default(now()) @updatedAt
  
  nguoiDungId  String
  nguoiDung    NguoiDung @relation(fields: [nguoiDungId], references: [id])
  
  truyenId     Int      // Thêm dòng này
  truyen       Truyen    @relation(fields: [truyenId], references: [id]) // Thêm dòng này

  chuongId     Int      
  chuong       Chuong    @relation(fields: [chuongId], references: [id])

  @@unique([nguoiDungId, truyenId]) // Cập nhật dòng này
}