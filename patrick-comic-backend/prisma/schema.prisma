generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NguoiDung {
  id           String      @id @default(cuid())
  tenDangNhap  String      @unique
  matKhau      String
  email        String?     @unique
  vaiTro       String      @default("USER")
  isBlocked    Boolean     @default(false)
  ngayTao      DateTime    @default(now())
  
  binhLuans    BinhLuan[]
  theoDois     TheoDoi[]
  lichSuDocs   LichSuDoc[]
}

model Truyen {
  id            Int         @id @default(autoincrement())
  tenTruyen     String
  tenKhongDau   String?   
  slug          String      @unique
  tacGia        String?
  moTa          String?
  thumbnail     String?   
  trangThai     String      @default("ĐANG_RA")
  luotXem       Int         @default(0)
  luotXemNgay   Int         @default(0)
  luotXemTuan   Int         @default(0)
  luotXemThang  Int         @default(0)
  ngayTao       DateTime    @default(now())
  ngayCapNhat   DateTime    @updatedAt

  chuongs       Chuong[]
  binhLuans     BinhLuan[]
  theoDois      TheoDoi[]
  theLoais      TheLoai[]
  lichSuDocs    LichSuDoc[] 

  // TỐI ƯU: Đánh index cho các trường tìm kiếm và sắp xếp bảng xếp hạng
  @@index([tenKhongDau]) 
  @@index([tenTruyen])
  @@index([ngayCapNhat(sort: Desc)]) // ⚡ Tăng tốc API trang chủ lấy truyện mới nhất cực mạnh!
  @@index([luotXem(sort: Desc)])
  @@index([luotXemNgay(sort: Desc)])   // ⚡ Phục vụ Fallback BXH Ngày
  @@index([luotXemTuan(sort: Desc)])   // ⚡ Phục vụ Fallback BXH Tuần
  @@index([luotXemThang(sort: Desc)])  // ⚡ Phục vụ Fallback BXH Tháng
}

model TheLoai {
  id      String   @id @default(cuid())
  ten     String   @unique
  truyens Truyen[]
}

model Chuong {
  id           Int           @id @default(autoincrement())
  tenChuong    String
  soChuong     Float         
  noiDung      String        
  ngayCapNhat  DateTime      @default(now())
  
  truyenId     Int
  truyen       Truyen        @relation(fields: [truyenId], references: [id])
  lichSuDocs   LichSuDoc[]
  binhLuans    BinhLuan[]
  baoLois      BaoLoi[]

  @@unique([truyenId, soChuong])
  @@index([truyenId]) // TỐI ƯU: Tìm toàn bộ chương của 1 truyện siêu tốc
}

model BinhLuan {
  id           String    @id @default(cuid())
  noiDung      String
  ngayBinhLuan DateTime  @default(now())
  
  nguoiDungId  String
  nguoiDung    NguoiDung @relation(fields: [nguoiDungId], references: [id])
  
  truyenId     Int
  truyen       Truyen    @relation(fields: [truyenId], references: [id])
  
  chuongId     Int?      
  chuong       Chuong?   @relation(fields: [chuongId], references: [id], onDelete: Cascade)

  // TỐI ƯU: Phục vụ cho tính năng lấy bình luận của truyện/chương theo thời gian mới nhất (Phân trang)
  @@index([truyenId, ngayBinhLuan(sort: Desc)])
  @@index([chuongId, ngayBinhLuan(sort: Desc)])
}

model TheoDoi {
  id           String    @id @default(cuid())
  ngayTheoDoi  DateTime  @default(now())
  
  nguoiDungId  String
  nguoiDung    NguoiDung @relation(fields: [nguoiDungId], references: [id])
  
  truyenId     Int
  truyen       Truyen    @relation(fields: [truyenId], references: [id])

  @@unique([nguoiDungId, truyenId])
  @@index([nguoiDungId]) // TỐI ƯU: Tải trang "Truyện đang theo dõi" của 1 user cụ thể cực nhanh
}

model LichSuDoc {
  id           String    @id @default(cuid())
  thoiGianDoc  DateTime  @default(now()) @updatedAt
  
  nguoiDungId  String
  nguoiDung    NguoiDung @relation(fields: [nguoiDungId], references: [id])
  
  truyenId     Int      
  truyen       Truyen    @relation(fields: [truyenId], references: [id])

  chuongId     Int      
  chuong       Chuong    @relation(fields: [chuongId], references: [id], onDelete: Cascade)

  @@unique([nguoiDungId, truyenId])
  @@index([nguoiDungId, thoiGianDoc(sort: Desc)]) // TỐI ƯU: Lấy lịch sử đọc của user để xếp từ mới đến cũ
}

model BaoLoi {
  id        String   @id @default(cuid())
  loaiLoi   String   
  moTa      String?  
  ngayTao   DateTime @default(now())
  
  chuongId  Int
  chuong    Chuong   @relation(fields: [chuongId], references: [id], onDelete: Cascade)

  @@index([chuongId]) // TỐI ƯU: Cho trang quản trị Admin lọc lỗi theo chương
}