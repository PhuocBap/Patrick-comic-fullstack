{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "ignoreDeprecations": "5.0",
    "rootDir": ".",  // <--- Thêm dòng này để chấp nhận cả src và api làm gốc
    "paths": {
      "@/*": ["./src/*"],
      "@lib/*": ["./src/lib/*"]
    },
    "types": ["node", "jest", "next-auth"],
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,
    "outDir": "./dist",
    "sourceMap": true,
    "incremental": true
  },
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules"]
}