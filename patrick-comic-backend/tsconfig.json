{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "ignoreDeprecations": "5.0",
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@lib/*": ["./src/lib/*"]
    },
    // 🔥 THAY ĐỔI: Xóa hoặc chuyển thành mảng rỗng để tự động quét node_modules/@types
    "types": [], 
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,
    "outDir": "./dist",
    "sourceMap": true,
    "incremental": true
  },
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules"]
}